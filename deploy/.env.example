# AIOS Production Environment Variables
# Copy to .env and customize: cp .env.example .env

# ---- Server ----
AIOS_HOST=0.0.0.0
AIOS_PORT=8000
AIOS_WORKERS=2
AIOS_LOG_LEVEL=info

# ---- Inference Provider ----
# Options: openai, ollama, vllm, mock
AIOS_PROVIDER=ollama
AIOS_MODEL=llama3.1:8b

# For OpenAI-compatible APIs (OpenAI, vLLM, Ollama)
AIOS_API_BASE=http://ollama:11434/v1
AIOS_API_KEY=

# ---- CORS ----
AIOS_CORS_ALLOW_ORIGINS=*

# ---- Rate Limiting ----
AIOS_RATE_LIMIT_ENABLED=true
AIOS_RATE_LIMIT_REQUESTS=60
AIOS_RATE_LIMIT_WINDOW=60

# ---- Memory ----
AIOS_MEMORY_TTL_HOURS=24
AIOS_MEMORY_MAX_ITEMS=1000

# ---- RAG ----
AIOS_RAG_CHUNK_SIZE=512
AIOS_RAG_TOP_K=5

# ---- Paths ----
AIOS_DATA_DIR=/data
AIOS_LOGS_DIR=/var/log/aios

# ---- Monitoring ----
AIOS_ENABLE_PROMETHEUS=true

# ---- Grafana (monitoring stack) ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=aiosadmin
