{
  "__inputs": [],
  "__requires": [],
  "title": "AIOS Production Dashboard",
  "uid": "aios-prod",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["aios", "production"],
  "timezone": "utc",
  "editable": false,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [{"expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{path}}"}],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 50, "color": "orange"}, {"value": 100, "color": "red"}]}
        }
      }
    },
    {
      "title": "P95 Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "P95"}],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 2, "color": "orange"}, {"value": 5, "color": "red"}]}
        }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100", "legendFormat": "Error %"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "orange"}, {"value": 5, "color": "red"}]}
        }
      }
    },
    {
      "title": "Host Memory",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "targets": [{"expr": "100 - (avg(node_memory_MemAvailable_bytes) / avg(node_memory_MemTotal_bytes) * 100)", "legendFormat": "Usage"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 70, "color": "orange"}, {"value": 90, "color": "red"}]}
        }
      }
    },
    {
      "title": "Host CPU",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "targets": [{"expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100", "legendFormat": "Usage"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 70, "color": "orange"}, {"value": 90, "color": "red"}]}
        }
      }
    },
    {
      "title": "GPU Memory",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [{"expr": "avg(nvidia_gpu_memory_used_bytes / nvidia_gpu_memory_total_bytes) * 100"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 80, "color": "orange"}, {"value": 95, "color": "red"}]}
        }
      }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [{"expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 80, "color": "orange"}, {"value": 90, "color": "red"}]}
        }
      }
    },
    {
      "title": "Container Status",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 16},
      "targets": [{"expr": "count(up == 1)", "legendFormat": "Up"}, {"expr": "count(up == 0)", "legendFormat": "Down"}],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0, "color": "red"}]}
        }
      }
    },
    {
      "title": "Rate Limited Requests",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 16},
      "targets": [{"expr": "rate(http_requests_total{status=\"429\"}[5m])", "legendFormat": "429/s"}],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "orange"}, {"value": 5, "color": "red"}]}
        }
      }
    },
    {
      "title": "Token Usage Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 16},
      "targets": [{"expr": "rate(aios_tokens_total[1m])", "legendFormat": "{{type}} tok/s"}],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}]}
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 16},
      "targets": [{"expr": "http_requests_active", "legendFormat": "Active"}],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 20, "color": "orange"}, {"value": 50, "color": "red"}]}
        }
      }
    }
  ]
}
