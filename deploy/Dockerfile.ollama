# Ollama inference server container
# Build: docker build -f deploy/Dockerfile.ollama -t aios-ollama:latest .
# Run:   docker run --gpus all -p 11434:11434 aios-ollama:latest

FROM ollama/ollama:latest

ENV OLLAMA_HOST=0.0.0.0 \
    OLLAMA_PORT=11434 \
    OLLAMA_KEEP_ALIVE=24h

EXPOSE 11434

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD ollama list || exit 1

ENTRYPOINT ["ollama", "serve"]
